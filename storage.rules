rules_version = '2';

/**
 * HandyHub — Firebase Storage Security Rules
 *
 * Buckets / paths:
 *   artisans/{artisanId}/documents/{file}  — KYC photos, ID scans, certificates
 *   customers/{customerId}/profile/{file}  — Profile photos
 *   shared/{allPaths}                      — App assets (read-only for authenticated users)
 *
 * Security principles:
 *   • Only the owner can WRITE to their own path
 *   • Any authenticated user can READ artisan profile photos (needed for browse)
 *   • Admins have full access (identified by email — Storage rules cannot query Firestore)
 *   • Maximum file size: 5 MB
 *   • Allowed types: images (JPEG, PNG, WebP, GIF) and PDF
 */

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper functions ───────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email in [
        'silas7korda@gmail.com',
        'clasceth4traders@gmail.com',
        'paakumisam@gmail.com'
      ];
    }

    function isValidFileSize() {
      // 5 MB limit
      return request.resource.size <= 5 * 1024 * 1024;
    }

    function isValidImageOrPdf() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf';
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // ── Artisan KYC documents ──────────────────────────────────────────────────
    // Selfie, Ghana Card front/back, business registration, certifications
    match /artisans/{artisanId}/documents/{file} {
      // Artisan can read their own docs; admins can read all (for KYC review)
      allow read: if isOwner(artisanId) || isSuperAdmin();

      // Artisan uploads their own docs during onboarding; admins can also upload
      allow write: if (isOwner(artisanId) || isSuperAdmin()) &&
                      isValidFileSize() &&
                      isValidImageOrPdf();

      allow delete: if isSuperAdmin();
    }

    // ── Customer profile photos ────────────────────────────────────────────────
    match /customers/{customerId}/profile/{file} {
      // Profile photos are visible to all signed-in users (needed for artisan-side chat)
      allow read: if isSignedIn();

      allow write: if isOwner(customerId) &&
                      isValidFileSize() &&
                      isValidImage();

      allow delete: if isOwner(customerId) || isSuperAdmin();
    }

    // ── Artisan profile photos (public-facing, shown on browse/search) ─────────
    match /artisans/{artisanId}/profile/{file} {
      allow read: if isSignedIn();

      allow write: if isOwner(artisanId) &&
                      isValidFileSize() &&
                      isValidImage();

      allow delete: if isOwner(artisanId) || isSuperAdmin();
    }

    // ── Chat attachments ───────────────────────────────────────────────────────
    match /chats/{chatId}/attachments/{file} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
                      isValidFileSize() &&
                      isValidImageOrPdf();
      allow delete: if isSuperAdmin();
    }

    // ── Admin uploads (verification documents, platform assets) ───────────────
    match /admin/{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── Deny everything else ───────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
