rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Each customer's profile image: only that user may write;
    // any authenticated user may read (needed to display avatars in chats/bookings).
    match /customers/{userId}/profileImage {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Artisan profile images follow the same pattern.
    match /artisans/{userId}/profileImage {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
