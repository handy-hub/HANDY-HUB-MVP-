{
  "indexes": [

    // ── customer_notifications ──────────────────────────────────────
    // subscribeToUserNotifications: receiverId + createdAt DESC
    {
      "collectionGroup": "customer_notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "receiverId", "order": "ASCENDING" },
        { "fieldPath": "createdAt",  "order": "DESCENDING" }
      ]
    },
    // subscribeToUnreadCount: receiverId + isRead
    {
      "collectionGroup": "customer_notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "receiverId", "order": "ASCENDING" },
        { "fieldPath": "isRead",     "order": "ASCENDING" }
      ]
    },

    // ── verification_requests ──────────────────────────────────────
    // admin queue: verificationStatus + submittedAt DESC
    {
      "collectionGroup": "verification_requests",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "verificationStatus", "order": "ASCENDING" },
        { "fieldPath": "submittedAt",         "order": "DESCENDING" }
      ]
    },
    // admin queue (all): submittedAt DESC (full history)
    {
      "collectionGroup": "verification_requests",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "submittedAt", "order": "DESCENDING" }
      ]
    },

    // ── verification_logs ───────────────────────────────────────────
    // getByArtisan: artisanId + timestamp DESC
    {
      "collectionGroup": "verification_logs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "artisanId",  "order": "ASCENDING" },
        { "fieldPath": "timestamp",  "order": "DESCENDING" }
      ]
    },

    // ── admin_notifications ─────────────────────────────────────────
    // getUnread: isRead + createdAt DESC
    {
      "collectionGroup": "admin_notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isRead",    "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // ── artisans ────────────────────────────────────────────────────
    // getTopRated: isAvailable + rating DESC
    {
      "collectionGroup": "artisans",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isAvailable", "order": "ASCENDING" },
        { "fieldPath": "rating",      "order": "DESCENDING" }
      ]
    },
    // findByCategory: category + rating DESC
    {
      "collectionGroup": "artisans",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "category", "order": "ASCENDING" },
        { "fieldPath": "rating",   "order": "DESCENDING" }
      ]
    },
    // dispatch.findEligibleArtisans: status + isAvailable + verificationStatus
    {
      "collectionGroup": "artisans",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",             "order": "ASCENDING" },
        { "fieldPath": "isAvailable",        "order": "ASCENDING" },
        { "fieldPath": "verificationStatus", "order": "ASCENDING" }
      ]
    },

    // ── bookings ────────────────────────────────────────────────────
    // subscribeByCustomerId (booking.html): customerId + createdAt DESC
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "customerId", "order": "ASCENDING" },
        { "fieldPath": "createdAt",  "order": "DESCENDING" }
      ]
    },
    // subscribeByArtisanId (jobs.html): artisanId + createdAt DESC
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "artisanId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // getByCustomerId filtered by status (one-shot)
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "customerId", "order": "ASCENDING" },
        { "fieldPath": "status",     "order": "ASCENDING" },
        { "fieldPath": "createdAt",  "order": "DESCENDING" }
      ]
    },
    // getByArtisanId filtered by status (one-shot)
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "artisanId", "order": "ASCENDING" },
        { "fieldPath": "status",    "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // artisanId + status + updatedAt — artisan dashboard active jobs
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "artisanId",  "order": "ASCENDING" },
        { "fieldPath": "status",     "order": "ASCENDING" },
        { "fieldPath": "updatedAt",  "order": "DESCENDING" }
      ]
    },
    // customerId + type — emergency booking queries
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "customerId", "order": "ASCENDING" },
        { "fieldPath": "type",       "order": "ASCENDING" },
        { "fieldPath": "createdAt",  "order": "DESCENDING" }
      ]
    },
    // dispatch.checkExpiredDispatches: dispatchStatus + responseDeadline ASC
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "dispatchStatus",   "order": "ASCENDING" },
        { "fieldPath": "responseDeadline", "order": "ASCENDING" }
      ]
    },

    // ── chats ────────────────────────────────────────────────────────
    // getChatsByUser / subscribeByUser: participants array-contains + lastMessageAt DESC
    {
      "collectionGroup": "chats",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "participants",  "arrayConfig": "CONTAINS" },
        { "fieldPath": "lastMessageAt", "order": "DESCENDING" }
      ]
    },

    // ── escrow ────────────────────────────────────────────────────────────────
    // holdFundsForBooking idempotency check: bookingId + customerId + status
    {
      "collectionGroup": "escrow",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "bookingId",  "order": "ASCENDING" },
        { "fieldPath": "customerId", "order": "ASCENDING" },
        { "fieldPath": "status",     "order": "ASCENDING" }
      ]
    },
    // getByCustomer: customerId + createdAt DESC
    {
      "collectionGroup": "escrow",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "customerId", "order": "ASCENDING" },
        { "fieldPath": "createdAt",  "order": "DESCENDING" }
      ]
    },
    // getByArtisan: artisanId + createdAt DESC
    {
      "collectionGroup": "escrow",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "artisanId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // getByStatus: status + createdAt DESC (admin)
    {
      "collectionGroup": "escrow",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",    "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // ── payouts ───────────────────────────────────────────────────────────────
    // getByUser: userId + createdAt DESC
    {
      "collectionGroup": "payouts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId",    "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // getByStatus (admin): status + createdAt DESC
    {
      "collectionGroup": "payouts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status",    "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    // getByUserType + status (admin): userType + status + createdAt DESC
    {
      "collectionGroup": "payouts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userType",  "order": "ASCENDING" },
        { "fieldPath": "status",    "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // ── commissions ──────────────────────────────────────────────────────────
    // getByArtisan: artisanId + createdAt DESC
    {
      "collectionGroup": "commissions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "artisanId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // ── artisan transactions subcollection ──────────────────────────────────
    // subscribeToArtisanTransactions: createdAt DESC
    {
      "collectionGroup": "transactions",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    // ── financialAudit ───────────────────────────────────────────────────────
    // getByUser: userId + createdAt DESC
    {
      "collectionGroup": "financialAudit",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId",    "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    }

  ],
  "fieldOverrides": []
}
